# Auto detect text files and normalize line endings to LF
* text=auto

# LaTeX files
*.tex text eol=lf
*.bib text eol=lf
*.sty text eol=lf
*.cls text eol=lf

# Python files
*.py text eol=lf
*.pyw text eol=lf

# Markdown and documentation
*.md text eol=lf
*.txt text eol=lf
*.rst text eol=lf

# Shell scripts
*.sh text eol=lf
*.bash text eol=lf

# Windows batch files
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# Binary files
*.pdf binary
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.mov binary
*.mp4 binary
*.mp3 binary
*.gz binary
*.zip binary
*.7z binary
*.ttf binary
*.otf binary
*.class binary
*.jar binary
